{
  "permissions": {
    "deny": [
      "Bash(cat .env*)",
      "Bash(echo .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(grep * .env*)"
    ],
    "allow": [
      "Bash(npm run *)",
      "Bash(git * main)",
      "Bash(* --version)",
      "Bash(mkdir:*)",
      "Bash(python3:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run dev)",
      "Bash(npm run buildTest)",
      "Bash(npm run buildProd)",
      "Bash(npm list *)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(echo *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(rm:*)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude has finished\" with title \"Claude Code\"' 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.params.message // \"Claude needs your attention\"' | { read -r msg; osascript -e \"display notification \\\"$msg\\\" with title \\\"Claude Code\\\"\"; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  }
}
